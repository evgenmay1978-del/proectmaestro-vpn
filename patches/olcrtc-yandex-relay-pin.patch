diff --git a/internal/engine/goolom/media.go b/internal/engine/goolom/media.go
index f0af72f..7b5c970 100644
--- a/internal/engine/goolom/media.go
+++ b/internal/engine/goolom/media.go
@@ -315,10 +315,42 @@ func (s *Session) applyServerHelloConfig(serverHello map[string]any) {
 	if len(iceServers) == 0 {
 		return
 	}
+	// Capture what the SFU advertised (URLs only; credentials redacted) so an
+	// on-device Rostov log shows exactly which relays Yandex offers there.
+	for _, ice := range iceServers {
+		logger.Infof("serverHello iceServer urls=%v has_cred=%t", ice.URLs, ice.Credential != "")
+	}
 	cfg := webrtc.Configuration{
 		ICEServers:   iceServers,
 		SDPSemantics: webrtc.SDPSemanticsUnifiedPlan,
 	}
+	if s.relayPin {
+		// FORCE the TURN-over-TCP-443 relay. Real Telemost survives the RU
+		// {Yandex,VK,MAX} whitelist by falling back to turn:...:443?transport=tcp
+		// when UDP is shaped. Our client otherwise nominates the UDP relay — it
+		// passes the whitelist by IP so ICE "connects", but shaped UDP carries no
+		// data → liveness death in ~1-2min (exactly the Rostov symptom). Keeping
+		// ONLY the tcp TURN makes pion gather ONLY the tcp relay candidate → media
+		// rides TCP-443 to a whitelisted Yandex IP, like real Telemost.
+		// Fail-open: if no transport=tcp entry is advertised, keep all rather than
+		// nulling the ICE set (→ dead session).
+		var tcp []webrtc.ICEServer
+		for _, ice := range iceServers {
+			for _, u := range ice.URLs {
+				if strings.Contains(u, "transport=tcp") {
+					tcp = append(tcp, ice)
+					break
+				}
+			}
+		}
+		if len(tcp) > 0 {
+			cfg.ICEServers = tcp
+			logger.Infof("goolom relay-pin: forcing TURN-over-TCP-443 (%d tcp server(s), dropped %d udp/stun)", len(tcp), len(iceServers)-len(tcp))
+		} else {
+			logger.Warnf("goolom relay-pin: no transport=tcp TURN advertised — keeping all (udp path may be shaped)")
+		}
+		cfg.ICETransportPolicy = webrtc.ICETransportPolicyRelay
+	}
 	if s.pcSub != nil {
 		_ = s.pcSub.SetConfiguration(cfg)
 	}
