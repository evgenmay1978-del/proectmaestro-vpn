# MaestroVPN TV backend (maestro-panel) — copy to /etc/maestro-panel.env, fill the
# __SET_ME__ values, chmod 600. Secrets NEVER go in the repo.

MAESTRO_LISTEN=127.0.0.1:8910
MAESTRO_STORE=/var/lib/maestro/customers.json
# admin API token — generate: openssl rand -hex 24
MAESTRO_ADMIN_TOKEN=__SET_ME__
# public HTTPS base the TV app hits for /sub and /claim (see DEPLOY.md, step 4 — TLS)
MAESTRO_SUB_BASE=https://wapmixx.ru:8910

# ── provisioning across both servers (set all to enable; leave XUI_BASE_URL empty to serve subscriptions only) ──
# 3x-ui panel (server 1). Bearer API token is the REAL auth — login is CSRF-blocked.
XUI_BASE_URL=https://wapmixx.ru:2053/33NXEZDAMyG5MLLw3x
XUI_HOST=wapmixx.ru
XUI_TOKEN=__3xui_API_token__       # == PANEL_API_TOKEN in /root/vpn_bot/.env
XUI_INSECURE=1
XUI_INBOUND=2                       # VLESS :443 inbound id ("moy2")

# server 2 (naive + hysteria) over SSH
S2_HOST=85.137.166.237
S2_USER=root
S2_PASSWORD=__server2_root_password__
S2_HY2_PORT=8443

# VLESS / Reality template (read from the 3x-ui :443 inbound — panel → inbound → Reality)
VLESS_SERVER=wapmixx.ru
VLESS_PORT=443
VLESS_SNI=__reality_sni__
VLESS_PBK=__reality_public_key__
VLESS_SID=__reality_short_id__
VLESS_FLOW=xtls-rprx-vision
VLESS_FP=chrome

# Hysteria2 template (server 2)
HY2_SERVER=wapmix.duckdns.org
HY2_SNI=wapmix.duckdns.org
HY2_INSECURE=1
