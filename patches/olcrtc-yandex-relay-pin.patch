+// logSelectedPair logs the NOMINATED ICE candidate pair for a PC — its type
+// (relay/host) and protocol (udp/tcp) + IP — so per connection we can SEE
+// whether media rides a Yandex relay over UDP (shaped in RU whitelist regions)
+// or TCP. The key observability for the Rostov UDP-shaping work; INFO, no verbose
+// flood. Best-effort — nil pair until ICE nominates one.
+func logSelectedPair(pc *webrtc.PeerConnection, which string) {
+	if pc == nil {
+		return
+	}
+	report := pc.GetStats()
+	var localID, remoteID string
+	for _, stat := range report {
+		if p, ok := stat.(webrtc.ICECandidatePairStats); ok && p.Nominated {
+			localID, remoteID = p.LocalCandidateID, p.RemoteCandidateID
+			break
+		}
+	}
+	if localID == "" {
+		logger.Infof("goolom %s selected pair: <none nominated yet>", which)
+		return
+	}
+	desc := func(id string) string {
+		if c, ok := report[id].(webrtc.ICECandidateStats); ok {
+			return fmt.Sprintf("%s/%s %s:%d", c.CandidateType, c.Protocol, c.IP, c.Port)
+		}
+		return "?"
+	}
+	logger.Infof("goolom %s SELECTED media pair: local[%s] <-> remote[%s]", which, desc(localID), desc(remoteID))
+}
