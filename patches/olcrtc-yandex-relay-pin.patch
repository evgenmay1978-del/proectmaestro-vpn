diff --git a/internal/engine/goolom/relaypin.go b/internal/engine/goolom/relaypin.go
new file mode 100644
index 0000000..4e533a4
--- /dev/null
+++ b/internal/engine/goolom/relaypin.go
@@ -0,0 +1,47 @@
+package goolom
+
+import "net"
+
+// yandexCIDRs are the Yandex (AS13238 and neighbours) ranges the Telemost SFU's
+// TURN relay candidates fall in. When a Session has relayPin set (client only),
+// the ICE candidate filter keeps ONLY candidates whose IP is inside one of these
+// ranges, so the client<->SFU media leg can ride ONLY whitelisted Yandex
+// infrastructure — the requirement for surviving RU {Yandex,VK,MAX} allowlist
+// regions. Mirrors the backend subgen olcrtcDirectCIDRs list; the verified live
+// relay IPs (77.88.7.x, 37.9.82.x, 37.9.102.x, 5.255.211.x) are all covered.
+var yandexCIDRs = mustParseCIDRs([]string{
+	"77.88.0.0/18",
+	"5.45.192.0/18",
+	"5.255.192.0/18",
+	"37.9.64.0/18",
+	"37.140.128.0/18",
+	"84.252.160.0/19",
+	"87.250.224.0/19",
+	"93.158.128.0/18",
+	"95.108.128.0/17",
+	"178.154.128.0/18",
+	"213.180.192.0/19",
+	"2a02:6b8::/32",
+})
+
+func mustParseCIDRs(cidrs []string) []*net.IPNet {
+	out := make([]*net.IPNet, 0, len(cidrs))
+	for _, c := range cidrs {
+		_, n, err := net.ParseCIDR(c)
+		if err != nil {
+			panic("goolom: bad yandex CIDR " + c + ": " + err.Error())
+		}
+		out = append(out, n)
+	}
+	return out
+}
+
+// ipInYandexCIDR reports whether ip is inside any known Yandex range.
+func ipInYandexCIDR(ip net.IP) bool {
+	for _, n := range yandexCIDRs {
+		if n.Contains(ip) {
+			return true
+		}
+	}
+	return false
+}
diff --git a/internal/engine/goolom/relaypin_test.go b/internal/engine/goolom/relaypin_test.go
new file mode 100644
index 0000000..2a78a4c
--- /dev/null
+++ b/internal/engine/goolom/relaypin_test.go
@@ -0,0 +1,34 @@
+package goolom
+
+import (
+	"net"
+	"testing"
+)
+
+func TestIPInYandexCIDR(t *testing.T) {
+	cases := []struct {
+		ip   string
+		want bool
+	}{
+		// Verified live Telemost TURN relay IPs — MUST pass the filter.
+		{"77.88.7.53", true},
+		{"37.9.82.148", true},
+		{"37.9.102.65", true},
+		{"5.255.211.241", true},
+		{"213.180.205.180", true}, // bootstrap STUN (stun.rtc.yandex.net)
+		// Non-Yandex — MUST be dropped so media can't leak off-whitelist.
+		{"46.30.42.151", false}, // S3 host (our exit)
+		{"8.8.8.8", false},      // Google DoT
+		{"1.1.1.1", false},
+		{"192.168.1.1", false},
+	}
+	for _, c := range cases {
+		ip := net.ParseIP(c.ip)
+		if ip == nil {
+			t.Fatalf("bad test ip %q", c.ip)
+		}
+		if got := ipInYandexCIDR(ip); got != c.want {
+			t.Errorf("ipInYandexCIDR(%s) = %v, want %v", c.ip, got, c.want)
+		}
+	}
+}
